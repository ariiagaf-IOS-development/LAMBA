{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lamba.local/schemas/digital-twin-v0.1.json",
  "title": "Digital Twin",
  "description": "Aggregated vehicle representation combining profile, lifecycle timeline, parts health, and prediction outputs.",
  "type": "object",
  "required": [
    "digital_twin_id",
    "schema_version",
    "generated_at",
    "vehicle",
    "timeline",
    "parts_health",
    "predictions",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "digital_twin_id": {
      "type": "string",
      "description": "Stable response identifier for this generated twin snapshot."
    },
    "schema_version": {
      "type": "string",
      "const": "digital-twin-v0.1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "vehicle": {
      "$ref": "#/$defs/vehicle_profile"
    },
    "timeline": {
      "type": "object",
      "required": [
        "taxonomy_version",
        "events"
      ],
      "additionalProperties": false,
      "properties": {
        "taxonomy_version": {
          "type": "string"
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/timeline_event"
          }
        }
      }
    },
    "parts_health": {
      "type": "object",
      "required": [
        "model_version",
        "parts"
      ],
      "additionalProperties": false,
      "properties": {
        "model_version": {
          "type": "string"
        },
        "parts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/part_health"
          }
        }
      }
    },
    "predictions": {
      "type": "object",
      "required": [
        "model_version",
        "source",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "model_version": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "rule_based",
            "mock",
            "ml_service"
          ]
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prediction"
          }
        }
      }
    },
    "summary": {
      "$ref": "#/$defs/digital_twin_summary"
    }
  },
  "$defs": {
    "vehicle_profile": {
      "type": "object",
      "required": [
        "id",
        "brand",
        "model",
        "year",
        "mileage_km"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer"
        },
        "user_id": {
          "type": "integer"
        },
        "brand": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "year": {
          "type": "integer"
        },
        "vin": {
          "type": [
            "string",
            "null"
          ]
        },
        "mileage_km": {
          "type": "integer",
          "minimum": 0
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "timeline_event": {
      "type": "object",
      "required": [
        "id",
        "vehicle_id",
        "type",
        "title",
        "event_date"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer"
        },
        "vehicle_id": {
          "type": "integer"
        },
        "type": {
          "type": "string",
          "enum": [
            "trip",
            "refuel",
            "repair",
            "inspection",
            "accident",
            "recall",
            "warning",
            "maintenance",
            "prediction",
            "diagnostic",
            "part_replacement",
            "note"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "mileage_km": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "cost": {
          "type": [
            "number",
            "null"
          ]
        },
        "event_date": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_id": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        },
        "metadata": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        }
      }
    },
    "part_health": {
      "type": "object",
      "required": [
        "part_category",
        "part_name",
        "health_score",
        "risk_level",
        "current_mileage_km",
        "recommendation"
      ],
      "additionalProperties": false,
      "properties": {
        "model_version": {
          "type": "string"
        },
        "part_category": {
          "type": "string"
        },
        "part_name": {
          "type": "string"
        },
        "health_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "risk_level": {
          "$ref": "#/$defs/risk_level"
        },
        "current_mileage_km": {
          "type": "integer",
          "minimum": 0
        },
        "mileage_since_service_km": {
          "type": [
            "integer",
            "null"
          ]
        },
        "remaining_km": {
          "type": [
            "integer",
            "null"
          ]
        },
        "recommendation": {
          "type": "string"
        }
      }
    },
    "prediction": {
      "type": "object",
      "required": [
        "part_name",
        "risk_level",
        "recommendation",
        "explanation"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer"
        },
        "vehicle_id": {
          "type": "integer"
        },
        "part_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "part_category": {
          "type": [
            "string",
            "null"
          ]
        },
        "part_name": {
          "type": "string"
        },
        "risk_level": {
          "$ref": "#/$defs/risk_level"
        },
        "risk_score": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "remaining_km": {
          "type": [
            "integer",
            "null"
          ]
        },
        "remaining_days": {
          "type": [
            "integer",
            "null"
          ]
        },
        "predicted_next_mileage": {
          "type": [
            "integer",
            "null"
          ]
        },
        "predicted_next_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "probability": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "recommendation": {
          "type": "string"
        },
        "explanation": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "digital_twin_summary": {
      "type": "object",
      "required": [
        "overall_risk_level",
        "highest_risk_parts",
        "open_warnings_count",
        "open_recalls_count",
        "latest_event_date",
        "next_recommended_actions"
      ],
      "additionalProperties": false,
      "properties": {
        "overall_risk_level": {
          "$ref": "#/$defs/risk_level"
        },
        "highest_risk_parts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_warnings_count": {
          "type": "integer",
          "minimum": 0
        },
        "open_recalls_count": {
          "type": "integer",
          "minimum": 0
        },
        "latest_event_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "next_recommended_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
