{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lamba.local/schemas/prediction-explanation.schema.json",
  "title": "Prediction Explanation",
  "description": "Structured explanation payload attached to each maintenance prediction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "explanation_text",
    "confidence",
    "confidence_qualifier",
    "confidence_score",
    "factors",
    "recommended_action"
  ],
  "properties": {
    "explanation_text": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable explanation of why the prediction was produced."
    },
    "confidence": {
      "type": "string",
      "enum": [
        "Low confidence",
        "Medium confidence",
        "High confidence"
      ],
      "description": "Human-readable confidence label for UI and AI Assistant responses."
    },
    "confidence_qualifier": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "description": "Machine-readable confidence bucket."
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Normalized confidence score derived from the selected risk probability."
    },
    "factors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/factor"
      },
      "description": "Ranked factors used to explain the prediction."
    },
    "recommended_action": {
      "type": "string",
      "minLength": 1,
      "description": "Next action recommended for the user or service advisor."
    }
  },
  "$defs": {
    "factor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "impact",
        "weight",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
